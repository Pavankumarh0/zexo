# Zexo API — environment template. Copy to .env and fill in. NEVER commit real secrets.

# App
ZEXO_ENV=development
ZEXO_DEBUG=true
ZEXO_PORT=8000

# Database (Supabase Postgres + PostGIS)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/zexo

# Supabase Auth (JWT validation)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_JWT_SECRET=replace-with-supabase-jwt-secret
SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key

# Redis (Upstash) for WebSocket pub/sub
REDIS_URL=rediss://default:password@your-upstash-host:6379

# Google OAuth
GOOGLE_OAUTH_CLIENT_ID=replace-with-google-client-id

# Firebase Cloud Messaging
FCM_PROJECT_ID=your-firebase-project
FCM_CREDENTIALS_JSON=

# Sentry
SENTRY_DSN=

# Discovery tuning
DISCOVER_WEIGHT_DISTANCE=0.6
DISCOVER_WEIGHT_TAG=0.4
LOCATION_FUZZ_METERS=150
RADIUS_MIN_M=500
RADIUS_MAX_M=50000
RADIUS_DEFAULT_M=5000
MESSAGE_TTL_HOURS=24
